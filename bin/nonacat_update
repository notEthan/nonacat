#!/usr/bin/env ruby

# Fetch Github's OpenAPI document from git ref ARGV[0] or the current `main` branch of https://github.com/github/rest-api-description
# For the gem, store the JSON compressed with zlib since, at 11 MB, it is rather excessive.
# For development, store the YAML for readability.

require('pathname')
require('net/http')
require('zlib')
require('json')
require('yaml')

api_dir = Pathname.new(__dir__).join('../github-rest-api-description')
api_dir.mkdir if !api_dir.exist?

def get_body(url)
  response = Net::HTTP.get_response(URI(url))
  raise("#{url} responded status: #{response.code}, body: #{response.body}") if !response.is_a?(Net::HTTPSuccess)
  response.body
end

ref = ARGV[0] || 'main'
commit = JSON.parse(get_body("https://api.github.com/repos/github/rest-api-description/commits/#{ref}"))

if (api_dir / 'updated.yml').exist? && YAML.safe_load_file(api_dir / 'updated.yml')['sha'] == commit['sha']
  STDERR.puts("already up to date at commit #{commit['sha']}; skipping (rm #{api_dir / 'updated.yml'} to force)")
  exit
end

STDERR.puts("fetching LICENSE.md")
(api_dir / 'LICENSE.md').write(get_body("https://raw.githubusercontent.com/github/rest-api-description/#{commit['sha']}/LICENSE.md"))

STDERR.puts("fetching api.github.com.json")
# getting this from the API is another option but it doesn't gzip so much slower
# at: "https://api.github.com/repos/github/rest-api-description/contents/descriptions/api.github.com/api.github.com.json?ref=#{commit['sha']}"
# with accept: 'application/vnd.github.raw'
api_json = get_body("https://raw.githubusercontent.com/github/rest-api-description/#{commit['sha']}/descriptions/api.github.com/api.github.com.json")
(api_dir / 'api.github.com.json.zz').write(Zlib.deflate(api_json))

# the YAML can be useful to browse for development but is excluded from the gem and git repo due to size
STDERR.puts("fetching api.github.com.yaml")
api_yaml = get_body("https://raw.githubusercontent.com/github/rest-api-description/#{commit['sha']}/descriptions/api.github.com/api.github.com.yaml")
(api_dir / 'api.github.com.yaml').write(api_yaml)

# sanity check
unless JSON.parse(api_json) == YAML.safe_load(api_yaml)
  abort("api.github.com.yaml != api.github.com.json")
end

(api_dir / 'updated.yml').write(YAML.dump({
  'comment' => "The commit from which other files in this directory were updated (using bin/nonacat_update)",
  'sha' => commit['sha'],
  'date' => commit['commit']['committer']['date'],
}))

STDERR.puts("updated!")
